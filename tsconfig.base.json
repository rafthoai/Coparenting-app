{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@coparenting/shared/*": ["packages/shared/src/*"],
      "@coparenting/rules-engine/*": ["packages/rules-engine/src/*"],
      "@coparenting/ai/*": ["packages/ai/src/*"],
      "@coparenting/api/*": ["packages/api/src/*"],
      "@coparenting/db/*": ["packages/db/src/*"]
    }
  }
}
